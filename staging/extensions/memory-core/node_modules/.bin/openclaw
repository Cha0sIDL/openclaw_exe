#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/proc/cygdrive/d/openclaw_exe/src/node_modules/.pnpm/openclaw@2026.3.2_@napi-rs+_f3ad5634f0c5b8a7671ba65ac99bfd49/node_modules/openclaw/node_modules:/proc/cygdrive/d/openclaw_exe/src/node_modules/.pnpm/openclaw@2026.3.2_@napi-rs+_f3ad5634f0c5b8a7671ba65ac99bfd49/node_modules:/proc/cygdrive/d/openclaw_exe/src/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/proc/cygdrive/d/openclaw_exe/src/node_modules/.pnpm/openclaw@2026.3.2_@napi-rs+_f3ad5634f0c5b8a7671ba65ac99bfd49/node_modules/openclaw/node_modules:/proc/cygdrive/d/openclaw_exe/src/node_modules/.pnpm/openclaw@2026.3.2_@napi-rs+_f3ad5634f0c5b8a7671ba65ac99bfd49/node_modules:/proc/cygdrive/d/openclaw_exe/src/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../openclaw/openclaw.mjs" "$@"
else
  exec node  "$basedir/../openclaw/openclaw.mjs" "$@"
fi
